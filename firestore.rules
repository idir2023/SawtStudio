rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}
    // Document ID: auto-generated (matches auth uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required) - 'admin' or 'user'
    //   - subscriptionTier: string (required) - 'free' or 'pro'
    //   - generationsCount: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/scripts
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who owns this script.
    //   - title: string (required, max 100) - A short title for the script.
    //   - text: string (required, max 5000) - The Arabic text to be narrated.
    //   - createdAt: timestamp (required) - When the script was created.
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "lahcenidir72@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidScript(userId) {
      return hasOnlyAllowedFields(['userId', 'title', 'text', 'createdAt']) &&
             hasRequiredFields(['userId', 'title', 'text', 'createdAt']) &&
             request.resource.data.userId == userId &&
             isValidStringLength('title', 1, 100) &&
             isValidStringLength('text', 1, 5000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidUserProfile() {
      return hasOnlyAllowedFields(['email', 'role', 'subscriptionTier', 'generationsCount', 'createdAt']) &&
             hasRequiredFields(['email', 'role', 'subscriptionTier', 'generationsCount', 'createdAt']) &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin', 'user'] &&
             request.resource.data.subscriptionTier in ['free', 'pro'] &&
             request.resource.data.generationsCount is number &&
             request.resource.data.generationsCount >= 0 &&
             request.resource.data.createdAt is timestamp;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow user to create their own profile. Role must be 'user' unless they are an admin.
      allow create: if isValidUserProfile() && 
                    ((isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.subscriptionTier == 'free') || isAdmin());
                    
      // Allow user to update their profile (e.g. incrementing generationsCount). 
      // They cannot change their role or subscriptionTier unless they are an admin.
      allow update: if isValidUserProfile() && 
                    (
                      (isOwner(userId) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.subscriptionTier == resource.data.subscriptionTier &&
                       areImmutableFieldsUnchanged(['email', 'createdAt'])) || 
                      isAdmin()
                    );
      allow list: if isAdmin();
    }

    match /users/{userId}/scripts/{scriptId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidScript(userId);
      allow update: if isOwner(userId) && isValidScript(userId) && areImmutableFieldsUnchanged(['userId', 'createdAt']);
      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
